graph TB
    subgraph DB["📊 DATABASES"]
        direction LR
        P["🏛️ 7 Pillars"]
        T["📋 140 Topics"]
        CT["🎬 12 Content Types"]
        PL["📱 7 Platforms"]
        CAT["🏷️ Categories"]
        SCHED["📅 Schedule"]
        Q["📬 Queue"]
    end

    subgraph PLAN["📝 PLANNING"]
        WTS["🗓️ Weekly Topic Selection"]
        CA["📌 Content Assignment<br/>Types × Platforms × Awareness"]
    end

    subgraph BRIEF["📄 MASTER BRIEFS"]
        B["✍️ Brief per Topic × Type"]
    end

    subgraph TOOLS["🏭 AI PRODUCTION TOOLS"]
        NB2["🖼️ NanaBanana 2<br/>━━━━━━━━━━━━<br/>Static Images<br/>Carousel Slides<br/>Thumbnails<br/>Quote Cards<br/>Pinterest Pins<br/>NLM Watermark Removal"]
        NLM["🧠 NotebookLM<br/>━━━━━━━━━━━━<br/>Video Explainers<br/>Audio Explainers<br/>Slide Decks<br/>Infographics<br/>⚠️ Raw output only"]
        REM["🎬 Remotion MCP<br/>━━━━━━━━━━━━<br/>Reels & Shorts<br/>Explainer Videos<br/>Carousel→Video<br/>A/B Variants<br/>Batch Render<br/>NLM Video Post-Proc"]
    end

    subgraph NLMPP["🔧 NLM POST-PROCESSING"]
        PPI["🖼️ Image Cleanup<br/>NanaBanana 2<br/>Remove watermarks"]
        PPV["🎬 Video Cleanup<br/>Trim ending +<br/>Remove watermark +<br/>Branded ending"]
        PPA["🔊 Audio Cleanup<br/>Trim ending +<br/>Branded ending"]
        VOX["🗣️ Voice AI<br/>Ending voiceover"]
    end

    subgraph ADAPT["🔄 PLATFORM ADAPTATION"]
        FB["📘 Facebook"]
        IG["📸 Instagram"]
        LI["💼 LinkedIn"]
        PIN["📌 Pinterest"]
        YT["▶️ YouTube"]
        WEB["🌐 Website"]
        EM["📧 Email"]
    end

    subgraph PUB["🚀 PUBLISH"]
        REV["✅ Quality Gates<br/>Science · Brand · Legal · Visual · SEO"]
        GO["📅 Schedule & Go Live"]
        PERF["📊 Track & Optimize"]
        REP["♻️ Repurpose"]
    end

    P --> WTS
    T --> WTS
    SCHED --> WTS
    WTS --> CA
    CT --> CA
    PL --> CA
    CAT --> CA
    CA --> B

    B --> NB2
    B --> NLM
    B --> REM

    NB2 --> FB
    NB2 --> IG
    NB2 --> LI
    NB2 --> PIN
    NLM -->|"Images"| PPI
    NLM -->|"Video"| PPV
    NLM -->|"Audio"| PPA
    VOX --> PPV
    VOX --> PPA
    PPI --> IG
    PPI --> LI
    PPI --> PIN
    PPV --> YT
    PPV --> WEB
    PPV --> LI
    PPA --> WEB
    REM --> IG
    REM --> YT
    REM --> FB

    B -.-> WEB
    B -.-> EM

    FB --> REV
    IG --> REV
    LI --> REV
    PIN --> REV
    YT --> REV
    WEB --> REV
    EM --> REV

    REV --> GO
    GO --> PERF
    PERF --> REP
    REP -.-> Q
    Q -.-> CA

    classDef dbStyle fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D47A1
    classDef planStyle fill:#FFF8E1,stroke:#F57F17,stroke-width:2px,color:#E65100
    classDef briefStyle fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#4A148C
    classDef toolStyle fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    classDef ppStyle fill:#FFF9C4,stroke:#F9A825,stroke-width:2px,color:#E65100
    classDef adaptStyle fill:#FBE9E7,stroke:#BF360C,stroke-width:2px,color:#BF360C
    classDef pubStyle fill:#E0F2F1,stroke:#00695C,stroke-width:2px,color:#004D40

    class P,T,CT,PL,CAT,SCHED,Q dbStyle
    class WTS,CA planStyle
    class B briefStyle
    class NB2,NLM,REM toolStyle
    class PPI,PPV,PPA,VOX ppStyle
    class FB,IG,LI,PIN,YT,WEB,EM adaptStyle
    class REV,GO,PERF,REP pubStyle
